<?xml version="1.0" encoding="utf-8"?>
<rule>
  <name>VBA2</name>
  <options>
    <documentation>
      One set of title block tags must be present in A1 Sheet Model or Modelsheet model.
      There should be no missing or duplicate tags.
    </documentation>
    <vb_project_name>CADCheckLibrary</vb_project_name>
    <vb_module_name>Checks</vb_module_name>
    <vb_function_name>CheckScript</vb_function_name>
    <vb_metadata>none</vb_metadata>
    <vb_parameters>

      <table name="TBTagsDrawing.tbl">
        <key>TBTagsDrawing</key>
        <source>TBTagsDrawing.csv</source>
      </table>
      
      <list name="TBTagsDrawing">
        <load_table_keys table="TBTagsDrawing.tbl" />
      </list>

      <list name="TBMultiTags">
        <pair>
          <key>RV_REV_1</key>
          <value>2</value>
        </pair>
      </list>

      <!-- Check for missing or duplicated tags in Title block sheet-->
      <verify>
        <when>
          <and>
            <test l="drawing" op="="><r><list_value key="type" listref="FileType"/></r></test>
          </and>
        </when>
        
        <select what="elements" >
          <models group="yes">
            <and>
                <test l="drawing" op="="><r><list_value key="type" listref="FileType"/></r></test>
                <test l="$model.type$" op="=" r="sheet" />
            </and>
          </models>
          <include_type>Tag</include_type>
          <where/>
        </select>

        <!-- check for duplicate and missing tags -->
        <count_list>
          <range>1</range>
          <key>$tagset$->$tag.name$</key>
          <list ref="TBTagsDrawing"/>

          <msg id="less">Error: Tag '{1}' was not found.</msg>
          <msg id="more">Error: Tag '{1}' was found {2} times.</msg>
        </count_list>

        <msg id="group-before">Checking title block tags in model '$model.name$'.</msg>
        <msg id="group-pass">Title block tags are correct.</msg>
      </verify>

      <verify>
        <when>
          <and>
            <test l="drawing" op="="><r><list_value key="type" listref="FileType"/></r></test>
          </and>
        </when>
          
        <select what="elements" >
          <models group="yes">
            <and>
                <test l="drawing" op="="><r><list_value key="type" listref="FileType"/></r></test>
                <test l="$model.type$" op="=" r="sheet" />
            </and>
          </models>
          <include_type>Tag</include_type>
          <where/>
        </select>

        <!-- check for duplicate and missing tags -->
        <count_list>
          <range>2</range>
          <key>$tagset$->$tag.name$</key>
          <list ref="TBMultiTags"/>

          <msg id="less">Error: Tag '{1}' was not found.</msg>
          <msg id="more">Error: Tag '{1}' was found {2} times.</msg>
        </count_list>

        <msg id="group-before">Checking title block tags in model '$model.name$'.</msg>
        <msg id="group-pass">Title block tags are correct.</msg>
      </verify>
      
<!--Update 16-10-2018 -->
<!--Added next section to check that SuitabilityCode Tag in ContentItemMetadata_1 TagSet contains a value-->

      <list name="TBValueTags">
        <pair>
          <key>Number</key>
          <value>Yes</value>
        </pair>
        <pair>
          <key>Project_No</key>
          <value>Yes</value>
        </pair>
      </list>

      <verify>
        <select what="elements" >
          <models group="yes">
            <test l="$model.type$" op="=" r="sheet"/>
          </models>
          <include_type>Tag</include_type>

          <where>
            <test l="$tag.tagset$" op="=" r="CLT-00001-TBlock"/>
          </where>
        </select>

        <!-- Report specific tags with no value -->
        <if>
          <where>
            <and>
              <test l="Yes" op="=">
                <r>
                  <list_value key="$tag.name$" listref="TBValueTags"/>
                </r>
              </test>
              <test l="$tag.value$" op="=" r=""/>
            </and>
          </where>
          <msg id="true" level="error">Error: $tag.name$ does not contain a value</msg>
        </if>
      </verify>

      <msg id="skip">Checking Skipped as not a valid file for checking based on Document Type</msg>
      <msg id="pass">No errors found. Check passed.</msg>
    </vb_parameters>
  </options>
</rule>
