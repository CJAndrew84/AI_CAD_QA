# ------------------------------
# Microsoft 365 Agents mode
# ------------------------------
M365_AGENTS_MESSAGES_ENDPOINT=https://your-agent-endpoint/messages
M365_AGENTS_BEARER_TOKEN=your_agent_bearer_token

# ------------------------------
# Azure OpenAI-style Copilot mode (fallback)
# ------------------------------
MS_COPILOT_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2024-02-15-preview
MS_COPILOT_API_KEY=your_api_key_here

# ------------------------------
# QA XML locations used by MCP tools (optional)
# ------------------------------
QA_MASTER_XML=./Rule XML Masters/Master.xml
QA_RULES_DIR=./Rule XML Files
